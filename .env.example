# Copy to .env and fill in. .env is gitignored — never commit real keys.
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Optional: where the device lives, used when GPS has no fix (always, indoors).
# Regional flavour for open-ended requests. e.g. "Barcelona, Spain"
SOUNDBUD_PLACE=

# Spotify — https://developer.spotify.com/dashboard
# Redirect URI must be exactly: http://127.0.0.1:8000/spotify/callback
# Reading what's playing works on a free account; starting playback needs Premium.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
